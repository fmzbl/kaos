#!/usr/bin/env bash
# Tinygrad CPU compiler bridge backed by the ziglang Python package.

set -eu

python_bin="${SISYPHUS_ZIGCC_PYTHON:-python3}"
export ZIG_GLOBAL_CACHE_DIR="${TMPDIR:-/tmp}/sisyphus-zig-cache-${USER:-user}"

translated=()
for argument in "$@"; do
  case "$argument" in
    --target=*-none-unknown-elf)
      architecture="${argument#--target=}"
      architecture="${architecture%%-*}"
      translated+=("--target=${architecture}-freestanding-none")
      ;;
    *) translated+=("$argument") ;;
  esac
done

exec "$python_bin" -m ziglang cc -g0 -fno-unwind-tables \
  -fno-asynchronous-unwind-tables "${translated[@]}"
